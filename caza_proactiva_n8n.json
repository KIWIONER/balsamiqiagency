        {
            "parameters": {
                "jsCode": "const rawText = $node[\"Gemini 2.5 Flash\"].json.candidates[0].content.parts[0].text;\nconst jsonMatch = rawText.match(/[\\{\\[]([\\s\\S]*?)[\\}\\]]/);\n\nif (!jsonMatch) {\n  return [{ json: { negocio: \"No se encontró JSON\", fallo_detectado: \"La IA no envió datos estructurados\", potencial_venta: \"Bajo\" } }];\n}\n\ntry {\n  let cleanJson = jsonMatch[0].replace(/```json|```/g, \"\").trim();\n  const data = JSON.parse(cleanJson);\n  const results = Array.isArray(data) ? data : [data];\n  \n  return results.map(item => ({\n    json: {\n      negocio: String(item.negocio || \"Sin nombre\"),\n      fallo_detectado: String(item.fallo_detectado || \"Sin detalles\"),\n      potencial_venta: String(item.potencial_venta || \"Medio\")\n    }\n  }));\n} catch (e) {\n  return [{ json: { negocio: \"Error de Formato\", fallo_detectado: e.message, potencial_venta: \"Bajo\" } }];\n}"
            },
