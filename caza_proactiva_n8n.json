                "jsonBody": "={{ { \"contents\": [ { \"parts\": [ { \"text\": \"Analiza estas quejas: \" + JSON.stringify($json.organic || []) + \"\\n\\nIdentifica negocios con fallos web. Devuelve SOLO un array JSON con: 'negocio', 'fallo_detectado', 'potencial_venta'. No escribas nada más.\" } ] } ] } }}",
