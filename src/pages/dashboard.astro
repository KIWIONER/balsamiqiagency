---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard de Operaciones | AgenciAlquimia">
    <div class="dashboard-container">
        <header class="dashboard-header">
            <div class="header-content">
                <h1>Comando de Operaciones <span class="highlight">Hunter</span></h1>
                <p>Monitor de Leads y Auditorías en Tiempo Real</p>
            </div>
            <div class="header-actions">
                <span id="connection-status" class="status-badge offline">Desconectado</span>
            </div>
        </header>

        <section class="dashboard-controls">
            <div class="filters">
                <input type="text" id="search-input" placeholder="Buscar empresa o sector..." />
                <select id="filter-priority">
                    <option value="all">Todas las Prioridades</option>
                    <option value="high">Alta Prioridad</option>
                    <option value="low">Baja Prioridad</option>
                </select>
            </div>
        </section>

        <section class="leads-grid" id="leads-grid">
            <!-- Leads will be injected here via JS -->
            <div class="empty-state" id="empty-state">
                <p>Cargando datos del enjambre...</p>
            </div>
        </section>
    </div>

    <style>
        .dashboard-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
            min-height: 100vh;
            color: var(--text-color);
        }

        .dashboard-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .dashboard-header h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }

        .status-badge {
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .status-badge::before {
            content: '';
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .status-badge.online {
            background: rgba(39, 201, 63, 0.1);
            color: #27c93f;
            border: 1px solid rgba(39, 201, 63, 0.3);
        }

        .status-badge.online::before {
            background: #27c93f;
            box-shadow: 0 0 8px #27c93f;
        }

        .status-badge.offline {
            background: rgba(255, 95, 86, 0.1);
            color: #ff5f56;
            border: 1px solid rgba(255, 95, 86, 0.3);
        }

        .status-badge.offline::before {
            background: #ff5f56;
        }

        .dashboard-controls {
            margin-bottom: 2rem;
            background: rgba(255, 255, 255, 0.02);
            padding: 1rem;
            border-radius: 8px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .filters {
            display: flex;
            gap: 1rem;
        }

        .filters input, .filters select {
            padding: 0.8rem;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            border-radius: 6px;
            font-family: inherit;
        }

        .filters input {
            flex: 1;
        }

        .leads-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 8px;
            border: 1px dashed rgba(255, 255, 255, 0.1);
            color: var(--text-muted);
        }
        
        .lead-card {
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            transition: all 0.3s ease;
        }
        
        .lead-card:hover {
            border-color: var(--accent-color);
            transform: translateY(-2px);
        }
        
        .lead-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        
        .lead-title h3 {
            font-size: 1.2rem;
            margin-bottom: 0.2rem;
        }
        
        .lead-meta {
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        
        .priority-badge {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
        }
        
        .priority-badge.high {
            background: rgba(255, 51, 102, 0.2);
            color: #ff3366;
            border: 1px solid rgba(255, 51, 102, 0.4);
        }
        
        .priority-badge.low {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-muted);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .lead-body {
            background: rgba(255, 255, 255, 0.02);
            padding: 1rem;
            border-radius: 8px;
            font-size: 0.9rem;
            line-height: 1.5;
            flex-grow: 1;
        }
        
        .lead-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: auto;
        }
        
        .action-btn {
            flex: 1;
            padding: 0.6rem;
            border-radius: 6px;
            border: none;
            font-size: 0.85rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            text-align: center;
        }
        
        .btn-audit {
            background: var(--accent-color);
            color: #000;
        }
        
        .btn-audit:hover {
            background: #fff;
        }
        
        .btn-demo {
            background: transparent;
            color: #fff;
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
        
        .btn-demo:hover {
            border-color: #fff;
            background: rgba(255,255,255,0.05);
        }
    </style>

    <script>
        import { supabase } from '../lib/supabase';

        let leads = [];

        async function initDashboard() {
            const statusBadge = document.getElementById('connection-status');
            const grid = document.getElementById('leads-grid');
            
            try {
                // Check if Supabase is configured
                if (!import.meta.env.PUBLIC_SUPABASE_URL || import.meta.env.PUBLIC_SUPABASE_URL.includes("YOUR_")) {
                    throw new Error("Supabase URLs no configuradas en .env");
                }

                // Initial fetch
                const { data, error } = await supabase
                    .from('objetivos_agencia') // Tabla configurada en N8N
                    .select('*')
                    .order('created_at', { ascending: false })
                    .limit(50);
                    
                if (error) throw error;
                
                leads = data || [];
                renderLeads();
                
                statusBadge.className = 'status-badge online';
                statusBadge.textContent = 'En Línea - Sincronizado';

                setupRealtime();
                setupFilters();
            } catch (err) {
                console.error("Dashboard Error:", err);
                statusBadge.className = 'status-badge offline';
                statusBadge.textContent = 'Desconectado - Revisar .env';
                
                if (grid) {
                    grid.innerHTML = `
                        <div class="empty-state" style="border-color: #ff5f56; color: #ff5f56;">
                            <p><strong>Error de Conexión</strong></p>
                            <p style="font-size: 0.9em; margin-top: 0.5rem; color: var(--text-muted);">${err.message}</p>
                            <p style="font-size: 0.8em; margin-top: 1rem;">Por favor, edita el archivo .env con tus credenciales de Supabase.</p>
                        </div>
                    `;
                }
            }
        }

        function setupRealtime() {
            // Suscripción a nuevos inserts
            supabase
                .channel('leads-channel')
                .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'objetivos_agencia' }, payload => {
                    console.log('Nuevo lead recibido!', payload.new);
                    leads = [payload.new, ...leads];
                    renderLeads();
                })
                .subscribe();
        }

        function renderLeads() {
            const grid = document.getElementById('leads-grid');
            if(!grid) return;
            
            const searchTerm = document.getElementById('search-input')?.value.toLowerCase() || "";
            const priorityFilter = document.getElementById('filter-priority')?.value || "all";
            
            const filteredLeads = leads.filter(lead => {
                const matchesSearch = (lead.empresa || lead.negocio || "").toLowerCase().includes(searchTerm) || 
                                      (lead.sector || "").toLowerCase().includes(searchTerm);
                                      
                // Asumimos 'alta' o 'baja' prioridad basada en la palabra reservar u otra lógica
                const isHighPriority = (lead.fallo_detectado || lead.senal_detectada || "").toLowerCase().includes('reservar');
                const matchesPriority = priorityFilter === 'all' || 
                                        (priorityFilter === 'high' && isHighPriority) || 
                                        (priorityFilter === 'low' && !isHighPriority);
                                        
                return matchesSearch && matchesPriority;
            });
            
            if (filteredLeads.length === 0) {
                grid.innerHTML = `
                    <div class="empty-state">
                        <p>No se encontraron prospectos${leads.length > 0 ? ' con estos filtros' : ''}.</p>
                    </div>
                `;
                return;
            }
            
            grid.innerHTML = filteredLeads.map(lead => {
                const empresa = lead.empresa || lead.negocio || "Empresa Desconocida";
                const sector = lead.sector || "Sector no definido";
                const problema = lead.fallo_detectado || lead.senal_detectada || "No se detectaron problemas específicos";
                const fecha = lead.created_at ? new Date(lead.created_at).toLocaleDateString() : 'Reciente';
                
                const isHighPriority = problema.toLowerCase().includes('reservar');
                const badgeClass = isHighPriority ? 'high' : 'low';
                const badgeText = isHighPriority ? 'HIGH PRIORITY' : 'STANDARD';
                
                return `
                    <div class="lead-card">
                        <div class="lead-header">
                            <div class="lead-title">
                                <h3>${empresa}</h3>
                                <span class="lead-meta">${sector} • ${fecha}</span>
                            </div>
                            <span class="priority-badge ${badgeClass}">${badgeText}</span>
                        </div>
                        <div class="lead-body">
                            <strong>Diagnóstico:</strong><br/>
                            ${problema}
                        </div>
                        <div class="lead-actions">
                            <button class="action-btn btn-audit" onclick="alert('Funcionalidad de auditoría en construcción')">Generar Auditoría</button>
                            ${isHighPriority ? `<button class="action-btn btn-demo" onclick="alert('Visor de demo en construcción')">Ver Demo</button>` : ''}
                        </div>
                    </div>
                `;
            }).join('');
        }

        function setupFilters() {
            document.getElementById('search-input')?.addEventListener('input', renderLeads);
            document.getElementById('filter-priority')?.addEventListener('change', renderLeads);
        }

        // Run when DOM is ready
        document.addEventListener('DOMContentLoaded', initDashboard);
    </script>
</Layout>
